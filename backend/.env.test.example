# Copy to .env.test and adjust for local testing.
# Matches docker-compose.test.yml by default.
DB_HOST=localhost
DB_PORT=55432
DB_NAME=alenstec_test
DB_USER=alenstec
DB_PASSWORD=alenstec_test

# Must be >= 32 chars — assertJwtSecret refuses shorter.
JWT_SECRET=test_secret_at_least_32_characters_long__
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=14d

SEED_DEFAULT_PASSWORD=test_password
